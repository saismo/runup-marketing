---
import '../styles/global.css';

const APP_URL = 'https://runup.saismo.at';

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
    title: 'No bars? No problem.',
    description: 'Works without a connection. Remote airstrip, mountain valley, middle of nowhere — your checklists don\'t care.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
    title: 'Different plane, different checklist.',
    description: 'Obvious? You\'d think so. Add a tail number, a photo, and each aircraft has its own setup. No mix-ups.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: 'All 10 phases. In order.',
    description: 'Pre-flight through Shutdown — every standard phase, every time. Memory is unreliable. Runup isn\'t.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
    title: 'iPhone to iPad, no drama.',
    description: 'Switch devices mid-trip and everything is already there. Like magic, but less mysterious. (Pro)',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Already have a checklist?',
    description: 'Great. Import it via CSV. We\'re not precious about where it came from — we just want you to have it.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`,
    title: 'Useful on day one.',
    description: 'A pre-loaded Cessna 172S checklist ships with the app. Open it, understand everything in 60 seconds, fly.',
  },
];

const freeFeatures = ['Single aircraft', 'All 10 flight phases', 'Offline access', 'Pre-loaded C172S demo'];
const proFeatures = ['Unlimited aircraft', 'All Free tier features', 'Cloud sync across devices', 'CSV checklist import', 'Priority support'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Runup — Flight checklists that actually go flying with you</title>
    <meta name="description" content="Runup keeps per-aircraft checklists on your phone for every flight phase, offline when you need it. Supplements your POH — free." />
  </head>
  <body class="m-0 bg-background font-sans text-foreground antialiased">
    <!-- NAV -->
    <nav id="nav" class="sticky top-0 z-50 px-6 transition-[background,backdrop-filter,box-shadow] duration-200">
      <div class="mx-auto flex h-16 max-w-[1100px] items-center justify-between">
        <img src="/logo.svg" alt="Runup" width="84" height="22" />
        <a href={APP_URL} class="btn-primary">Get Runup — Free</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="px-6 pt-20 pb-24">
      <div class="mx-auto max-w-[760px] text-center">
        <span class="fade-up mb-8 inline-flex items-center rounded-full border border-border bg-card px-3.5 py-1.5 text-sm font-medium tracking-wide text-muted-foreground" style="animation-delay: 0s;">
          No paper &nbsp;·&nbsp; No Wi-Fi required &nbsp;·&nbsp; No excuses
        </span>
        <h1 class="fade-up mt-0 mb-5 text-[clamp(2.4rem,6vw,4rem)] font-extrabold tracking-[-0.03em] text-foreground" style="animation-delay: 0.1s; line-height: 1.1;">
          Memory is not a checklist.
        </h1>
        <p class="fade-up mx-auto mb-4 max-w-full text-lg leading-relaxed text-pretty text-muted-foreground" style="animation-delay: 0.2s;">
          Paper checklists get soggy. Laminated ones get lost. Runup keeps your checklists on your phone, organized by aircraft and ready for every phase of flight, even offline.
        </p>
        <p class="fade-up mx-auto mb-10 max-w-full text-base leading-relaxed text-muted-foreground" style="animation-delay: 0.2s;">
          It supplements your POH. It doesn't replace it. Nothing does.
        </p>
        <div class="fade-up flex flex-wrap items-center justify-center gap-3" style="animation-delay: 0.3s;">
          <a href={APP_URL} class="btn-primary btn-primary-lg">Try it free</a>
          <a href="#features" class="rounded-lg px-2 py-3.5 text-base font-medium text-primary underline-offset-4 hover:underline">
            See what's included ↓
          </a>
        </div>
      </div>
    </section>

    <!-- APP SHOWCASE: soft bg + two tilted, overlapping phones (style ref — not the example asset) -->
    <section
      id="showcase"
      class="showcase-section relative overflow-hidden bg-background px-6 py-16 md:py-24"
      aria-label="App preview"
    >
      <div class="showcase-bg pointer-events-none absolute inset-0 z-0" aria-hidden="true"></div>
      <div class="showcase-devices relative z-10 mx-auto">
        <figure class="phone-mockup phone-mockup--back m-0">
          <figcaption class="sr-only">Placeholder iPhone — aircraft / home</figcaption>
          <div class="phone-mockup-notch" aria-hidden="true"></div>
          <div class="phone-mockup-screen">
            <span class="text-center text-xs font-medium text-muted-foreground">Home / aircraft list</span>
          </div>
        </figure>
        <figure class="phone-mockup phone-mockup--front m-0">
          <figcaption class="sr-only">Placeholder iPhone — checklist</figcaption>
          <div class="phone-mockup-notch" aria-hidden="true"></div>
          <div class="phone-mockup-screen">
            <span class="text-center text-xs font-medium text-muted-foreground">Checklist in flight</span>
          </div>
        </figure>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="px-6 py-24">
      <div class="mx-auto max-w-[1100px]">
        <div class="mb-14 text-center">
          <span class="mb-4 inline-flex items-center rounded-full border border-border bg-card px-3.5 py-1.5 text-sm font-medium text-muted-foreground">
            Why pilots use Runup
          </span>
          <h2 class="m-0 text-[clamp(1.8rem,4vw,2.5rem)] font-extrabold tracking-[-0.03em] text-foreground">
            Refreshingly no-nonsense.
          </h2>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-5">
          {features.map((f, i) => (
            <div
              class="feature-card fade-up rounded-xl bg-card p-7 shadow-small ring-1 ring-foreground/10"
              style={`animation-delay: ${0.05 * i}s`}
            >
              <div class="mb-4 text-primary" set:html={f.icon} />
              <h3 class="mb-2 text-base font-bold tracking-[-0.01em] text-foreground">{f.title}</h3>
              <p class="m-0 text-sm leading-relaxed text-muted-foreground">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DEMO -->
    <section class="px-6 py-24">
      <div class="demo-grid mx-auto max-w-[1100px] grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div>
          <span class="mb-5 inline-flex items-center rounded-full border border-border bg-card px-3.5 py-1.5 text-sm font-medium text-muted-foreground">
            See it in action
          </span>
          <h2 class="mb-4 text-[clamp(1.8rem,3.5vw,2.25rem)] font-extrabold leading-tight tracking-[-0.03em] text-foreground">
            Useful on day one.<br />Not after a tutorial.
          </h2>
          <p class="mb-6 text-base leading-relaxed text-muted-foreground">
            Runup ships with a pre-loaded Cessna 172S checklist. You open the app, you understand how it works, you fly. That's the whole onboarding experience.
          </p>
          <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
            {['Pick a phase', 'Check items off one by one', 'See what you missed before you move on'].map(item => (
              <li class="flex items-center gap-2.5 text-base text-muted-foreground">
                <span class="font-bold text-primary">✓</span> {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative flex h-80 overflow-hidden rounded-xl bg-muted shadow-small ring-1 ring-foreground/10">
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-2">
            <span class="rounded-full bg-foreground/10 px-5 py-2 text-sm font-medium text-muted-foreground backdrop-blur-sm">Screenshots coming soon</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="pricing" class="bg-card px-6 py-24">
      <div class="mx-auto max-w-[860px]">
        <div class="mb-14 text-center">
          <span class="mb-4 inline-flex items-center rounded-full border border-border bg-background px-3.5 py-1.5 text-sm font-medium text-muted-foreground">
            Pricing
          </span>
          <h2 class="m-0 text-[clamp(1.8rem,4vw,2.5rem)] font-extrabold tracking-[-0.03em] text-foreground">
            No catch. No credit card. Just fly.
          </h2>
        </div>
        <div class="pricing-grid grid grid-cols-1 items-start gap-6 sm:grid-cols-2">
          <!-- Free -->
          <div class="rounded-xl border border-border bg-background p-8">
            <p class="section-label">Free</p>
            <p class="mb-1 text-4xl font-extrabold tracking-[-0.04em] text-foreground">$0</p>
            <p class="mb-7 text-sm text-muted-foreground">Forever free</p>
            <a href={APP_URL} class="btn-outline btn-primary-block mb-7 text-center">Get started</a>
            <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
              {freeFeatures.map(f => (
                <li class="flex items-center gap-2.5 text-sm text-muted-foreground">
                  <span class="text-primary">✓</span> {f}
                </li>
              ))}
            </ul>
          </div>
          <!-- Pro -->
          <div class="relative rounded-xl border-2 border-primary bg-card p-8 shadow-small ring-4 ring-primary/10">
            <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 whitespace-nowrap rounded-full bg-primary px-3 py-1 text-xs font-bold tracking-wide text-primary-foreground">
              Coming soon
            </span>
            <p class="section-label !text-primary">Pro</p>
            <p class="mb-1 text-4xl font-extrabold tracking-[-0.04em] text-foreground">TBD</p>
            <p class="mb-7 text-sm text-muted-foreground">Billed monthly</p>
            <button type="button" disabled class="btn-primary btn-primary-block mb-7">Coming soon</button>
            <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
              {proFeatures.map(f => (
                <li class="flex items-center gap-2.5 text-sm text-muted-foreground">
                  <span class="text-primary">✓</span> {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA REPEAT -->
    <section class="bg-primary px-6 py-20 text-center">
      <h2 class="mx-auto mb-4 max-w-[640px] text-[clamp(1.8rem,4vw,2.5rem)] font-extrabold leading-tight tracking-[-0.03em] text-primary-foreground">
        The weather's clear.<br />The checklist is loaded.<br />What are you waiting for?
      </h2>
      <p class="mx-auto mb-9 max-w-[420px] text-base leading-relaxed text-primary-foreground/75">
        Free. No signup required. Your POH still comes along for the ride.
      </p>
      <a href={APP_URL} class="btn-on-primary">Open Runup</a>
    </section>

    <!-- FOOTER -->
    <footer class="bg-foreground px-6 py-12">
      <div class="mx-auto max-w-[1100px]">
        <div class="mb-10 flex flex-wrap items-start justify-between gap-8">
          <img src="/logo.svg" alt="Runup" width="84" height="22" class="opacity-60 brightness-0 invert" />
          <a href={APP_URL} class="text-sm text-white/50 no-underline hover:text-white/70">Open app →</a>
        </div>
        <div class="border-t border-white/10 pt-7">
          <p class="mb-3 max-w-[700px] text-sm leading-relaxed text-white/40">
            <strong class="font-semibold text-white/60">Safety disclaimer:</strong> Runup is a supplementary tool only. You, as pilot-in-command, are solely responsible for the safe conduct of each flight and for verifying all checklist items against the official POH/AFM for your aircraft.
          </p>
          <p class="m-0 text-sm text-white/25">
            © {new Date().getFullYear()} Runup. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up {
      opacity: 1;
      animation: none;
    }
  }

  .feature-card {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-dialog);
  }

  .showcase-bg {
    background-color: var(--background);
    background-image: url('/devices-background.jpg');
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
  }

  /* Stage size so rotated phones don’t clip; overlap + opposing tilts like product hero refs */
  .showcase-devices {
    height: min(520px, 78vw);
    max-width: 56rem;
  }

  @media (min-width: 768px) {
    .showcase-devices {
      height: min(580px, 70vw);
    }
  }

  .phone-mockup {
    position: absolute;
    left: 50%;
    top: 50%;
    display: flex;
    width: min(15.5rem, 42vw);
    flex-direction: column;
    aspect-ratio: 9 / 19.5;
    border-radius: 2.35rem;
    border: 2px solid color-mix(in srgb, var(--foreground) 88%, white);
    background: var(--card);
    padding: 0.35rem;
    box-shadow: none;
    transform-origin: center center;
  }

  .phone-mockup--back {
    z-index: 1;
    width: min(14.5rem, 38vw);
    transform: translate(calc(-50% - clamp(2.75rem, 12vw, 5.5rem)), -50%) rotate(-14deg);
    filter: drop-shadow(0 20px 36px rgba(53, 64, 92, 0.2))
      drop-shadow(0 6px 14px rgba(53, 64, 92, 0.1));
  }

  .phone-mockup--front {
    z-index: 2;
    width: min(16rem, 44vw);
    transform: translate(calc(-50% + clamp(2.25rem, 10vw, 4.75rem)), -50%) rotate(13deg);
    filter: drop-shadow(0 24px 44px rgba(53, 64, 92, 0.24))
      drop-shadow(0 8px 18px rgba(53, 64, 92, 0.12));
  }

  @media (max-width: 640px) {
    .showcase-devices {
      height: min(440px, 92vw);
    }

    .phone-mockup--back {
      transform: translate(calc(-50% - 1.75rem), -46%) rotate(-11deg) scale(0.92);
    }

    .phone-mockup--front {
      transform: translate(calc(-50% + 1.75rem), -54%) rotate(11deg) scale(0.96);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-mockup--back {
      transform: translate(calc(-50% - 3rem), -50%);
      filter: drop-shadow(0 12px 24px rgba(53, 64, 92, 0.15));
    }

    .phone-mockup--front {
      transform: translate(calc(-50% + 3rem), -50%);
      filter: drop-shadow(0 12px 24px rgba(53, 64, 92, 0.15));
    }
  }

  .phone-mockup-notch {
    position: absolute;
    top: 0.5rem;
    left: 50%;
    z-index: 1;
    width: 32%;
    height: 1.4rem;
    border-radius: 999px;
    background: var(--foreground);
    transform: translateX(-50%);
  }

  .phone-mockup-screen {
    display: flex;
    min-height: 0;
    flex: 1;
    align-items: center;
    justify-content: center;
    margin-top: 1.9rem;
    border-radius: 1.4rem;
    background: var(--muted);
    padding: 1rem;
  }

</style>

<style is:global>
  /* Global so JS `classList.toggle('scrolled')` always matches (not scoped to data-astro-*). */
  #nav.scrolled {
    background: color-mix(in srgb, var(--background) 90%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow:
      0px 12px 56px rgba(53, 64, 92, 0.1),
      0px 5px 23px rgba(53, 64, 92, 0.07),
      0px 2.7px 12.5px rgba(53, 64, 92, 0.06),
      0px 1.5px 7px rgba(53, 64, 92, 0.05),
      0px 0.8px 3.7px rgba(53, 64, 92, 0.04),
      0px 0.33px 1.55px rgba(53, 64, 92, 0.03);
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });
</script>
